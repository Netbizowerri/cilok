# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Formspree endpoint IDs for each form on the site.
# Create forms at https://formspree.io and paste the ID (the hash part) below.
# ✅ Correct: VITE_FORMSPREE_CONTACT=mdavjgwl
# ✅ Also works: VITE_FORMSPREE_CONTACT=https://formspree.io/f/mdavjgwl
# ❌ Wrong: VITE_FORMSPREE_CONTACT=https://formspree.io/f/https://formspree.io/f/mdavjgwl
VITE_FORMSPREE_CONTACT=
VITE_FORMSPREE_CONSULTATION=
VITE_FORMSPREE_PRODUCT_ORDER=
VITE_FORMSPREE_SERVICE_BOOKING=

# Privyr CRM webhook integration.
# Get your webhook URL from Privyr app > Integrations > Webhooks.
# VITE_PRIVYR_WEBHOOK_URL=https://www.privyr.com/api/v1/incoming-leads/your-id/your-token
# VITE_PRIVYR_TOKEN=your_privyr_auth_token
VITE_PRIVYR_WEBHOOK_URL=
VITE_PRIVYR_TOKEN=
